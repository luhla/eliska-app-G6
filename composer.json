{
    "name": "eliska/eliskapp",
    "description": "Eliskapp - AAC communication board for cognitively impaired children",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "nette/application": "^3.2",
        "nette/bootstrap": "^3.2",
        "nette/database": "^3.2",
        "nette/di": "^3.2",
        "nette/forms": "^3.2",
        "nette/http": "^3.2",
        "nette/routing": "^3.1",
        "nette/security": "^3.2",
        "nette/utils": "^4.0",
        "latte/latte": "^3.0",
        "tracy/tracy": "^2.10"
    },
    "require-dev": {
        "nette/tester": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php -r \"@mkdir('temp/cache', 0777, true); @mkdir('temp/sessions', 0777, true); @mkdir('log', 0777, true); @mkdir('www/uploads/images', 0777, true); @mkdir('www/uploads/audio', 0777, true);\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
