<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{ifset title}{include title} – {/ifset}Eliskapp Admin</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="/css/admin.css">
{block head}{/block}
</head>
<body class="admin-body">

<div class="admin-wrapper">

    <!-- Sidebar -->
    <nav class="admin-sidebar" id="sidebar">
        <div class="sidebar-brand">
            <i class="bi bi-chat-square-heart-fill me-2"></i>
            <span>Eliskapp</span>
        </div>
        <ul class="sidebar-nav">
            <li class:active="$activePresenter === 'Admin:Dashboard'">
                <a n:href="Dashboard:default"><i class="bi bi-house-fill"></i> Přehled</a>
            </li>
            <li class:active="$activePresenter === 'Admin:Block'">
                <a n:href="Block:default"><i class="bi bi-grid-3x3-gap-fill"></i> Bloky</a>
            </li>

            <li class:active="$activePresenter === 'Admin:Settings'">
                <a n:href="Settings:default"><i class="bi bi-gear-fill"></i> Nastavení</a>
            </li>
            <li class:active="$activePresenter === 'Admin:User'">
                <a n:href="User:default"><i class="bi bi-people-fill"></i> Uživatelé</a>
            </li>
        </ul>
        <div class="sidebar-footer">
            <a href="/go/{$userUid}" target="_blank" class="btn btn-sm btn-outline-light w-100 mb-2">
                <i class="bi bi-eye-fill"></i> Zobrazit jako dítě
            </a>
            <a n:href="Login:signOut" class="btn btn-sm btn-danger w-100">
                <i class="bi bi-box-arrow-right"></i> Odhlásit se
            </a>
        </div>
    </nav>

    <!-- Main content -->
    <div class="admin-main">

        <!-- Top bar -->
        <header class="admin-topbar">
            <button class="btn btn-sm btn-outline-secondary d-lg-none" id="sidebarToggle">
                <i class="bi bi-list"></i>
            </button>
            <span class="ms-auto text-muted small">
                <i class="bi bi-person-circle me-1"></i>{$loggedUser}
            </span>
        </header>

        <!-- Flash messages -->
        {foreach $flashes as $flash}
        <div class="alert alert-{$flash->type} alert-dismissible fade show mx-3 mt-3" role="alert">
            {$flash->message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        {/foreach}

        <!-- Page content -->
        <main class="admin-content">
            {block content}{/block}
        </main>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.3/Sortable.min.js"></script>
<script>
// Sidebar toggle for mobile
document.getElementById('sidebarToggle')?.addEventListener('click', function() {
    document.getElementById('sidebar').classList.toggle('show');
});
</script>
{block scripts}{/block}
</body>
</html>
